<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    android:id="@+id/transaction_card_layout"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Indicator Bar (Used for color coding in Java) -->
        <View
            android:id="@+id/vIndicator"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#CF6679"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Principal Suspect (Vendor) -->
        <TextView
            android:id="@+id/tvRowSuspect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="SUSPECT: STARBUCKS"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            app:layout_constraintStart_toEndOf="@id/vIndicator"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tvRowAmount"
            android:layout_marginEnd="8dp"/>

        <!-- Date of Incident -->
        <TextView
            android:id="@+id/tvRowDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="DATE: 10/24/2023"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            app:layout_constraintTop_toBottomOf="@id/tvRowSuspect"
            app:layout_constraintStart_toEndOf="@id/vIndicator"
            android:layout_marginTop="4dp"/>

        <!-- Financial Impact (Amount) -->
        <TextView
            android:id="@+id/tvRowAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-$5.75"
            android:textColor="#CF6679"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.cardview.widget.CardView>